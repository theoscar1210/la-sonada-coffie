# ============================================================
# LA SOÑADA COFFIE — Variables de entorno
# Copia este archivo a .env y completa los valores reales
# NUNCA commitees .env con valores reales a git
# ============================================================

# ---- Base de Datos ----
# Obtener de tu proveedor (Railway, Neon, Supabase, etc.)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/la_sonada_coffie?schema=public"

# ---- Autenticación JWT ----
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="GENERAR_64_BYTES_HEX_ALEATORIO"
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_REFRESH_SECRET="GENERAR_64_BYTES_HEX_ALEATORIO_DIFERENTE"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ---- Stripe ----
# Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
# Dashboard: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET="whsec_..."
# Esta clave SÍ puede ir pública (prefijo NEXT_PUBLIC_)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ---- Sanity CMS ----
# Dashboard: https://www.sanity.io/manage
SANITY_PROJECT_ID="tu-project-id"
SANITY_DATASET="production"
SANITY_API_TOKEN="token-con-permisos-de-escritura"
NEXT_PUBLIC_SANITY_PROJECT_ID="tu-project-id"
NEXT_PUBLIC_SANITY_DATASET="production"

# ---- Cloudinary (imágenes) ----
# Dashboard: https://cloudinary.com/console
# CLOUDINARY_API_SECRET NUNCA va con prefijo NEXT_PUBLIC_
CLOUDINARY_CLOUD_NAME="tu-cloud-name"
CLOUDINARY_API_KEY="tu-api-key"
CLOUDINARY_API_SECRET="tu-api-secret-SOLO-EN-BACKEND"
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="tu-cloud-name"

# ---- Next.js ----
NEXT_PUBLIC_API_URL="http://localhost:3001"
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET="GENERAR_32_BYTES_HEX_ALEATORIO"
NEXTAUTH_URL="http://localhost:3000"

# ---- API (Fastify) ----
PORT=3001
HOST="0.0.0.0"
FRONTEND_URL="http://localhost:3000"
ADMIN_URL="http://localhost:3002"

# ---- Panel Admin (Vite — prefijo VITE_) ----
VITE_API_URL="http://localhost:3001"

# ---- Entorno ----
NODE_ENV="development"
